# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ============================================
# DOMAIN & SECURITY
# ============================================
DOMAIN=certchain.yourdomain.com
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARACTERS_LONG

# ============================================
# WEBAUTHN (Biometric Authentication)
# ============================================
WEBAUTHN_RP_NAME=CertChain
WEBAUTHN_RP_ID=certchain.yourdomain.com
WEBAUTHN_ORIGIN=https://certchain.yourdomain.com

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=https://certchain.yourdomain.com
REACT_APP_API_URL=https://certchain.yourdomain.com/api

# ============================================
# BLOCKCHAIN
# ============================================
# Contract address after deployment
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
REACT_APP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# RPC URL - Use Alchemy, Infura, or your own node
# Polygon Mumbai (Testnet): https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY
# Polygon Mainnet: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# Ethereum Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Admin wallet private key (KEEP THIS SECRET!)
ADMIN_WALLET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ============================================
# DATABASE
# ============================================
# For Docker deployment (internal network)
MONGODB_URI=mongodb://mongodb:27017/certchain

# For MongoDB Atlas (cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/certchain?retryWrites=true&w=majority

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production
PORT=5000
JWT_EXPIRES_IN=7d
