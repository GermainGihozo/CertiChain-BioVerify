{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "build"
    },
    "backend": {
      "root": "backend",
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/health",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/build/index.html"
    }
  ]
}
